generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model User {
  id            String         @id @default(uuid())
  username      String         @unique
  email         String         @unique
  name          String
  password      String 
  role          Role           @default(STAFF)
  
  // Relations
  projects      Project[]      // Projects created by this user (Admin role only)
  assignments   Assignment[]   // Assignments assigned to this user (Staff role only)
  refreshTokens RefreshToken[]
  
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Project {
  id          String       @id @default(uuid())
  name        String
  description String?      @db.Text
  image       String?     
  userId      String       
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relations
  assignments Assignment[]
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Assignment {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  projectId   String    
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String    
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relations
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id           String     @id @default(uuid())
  name         String
  description  String?    @db.Text
  status       TaskStatus @default(TODO)
  
  // File upload for staffs regarding tasks, store string only!
  attachmentUrl  String?
  attachmentName String?
  
  assignmentId String    
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
